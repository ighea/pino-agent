# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- LLM (OpenAI-compatible) ---
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=gemma4:e4b
FAST_MODEL=qwen2.5:1.5b  # quick-acknowledgment model; set empty to disable

# --- Search ---
BRAVE_API_KEY=your_brave_api_key_here

# --- Weather ---
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# --- Workspace & data (file tools, logs, memory) ---
# WORKSPACE_DIR=./data/workspace     # sandboxed directory for file tools
# AGENT_LOG_FILE=data/agent_history.jsonl
# HTTP_PUBLIC_URL=https://pino.example.com  # base URL used in share_file download links (HTTP trigger)

# --- Calendars (ICS) ---
# Name each calendar with CALENDAR_<name>=<ics_url>
# Get each URL from: Google Calendar → Settings → calendar → "Secret address in iCal format"
# CALENDAR_PERSONAL=https://calendar.google.com/calendar/ical/...
# CALENDAR_WORK=https://calendar.google.com/calendar/ical/...
# CALENDAR_WIFE=https://calendar.google.com/calendar/ical/...

# --- Reminders ---
REMINDERS_FILE=data/reminders.json

# --- Daily briefing ---
# DAILY_BRIEFING_TIME=08:00        # HH:MM in DAILY_BRIEFING_TZ
# DAILY_BRIEFING_TZ=Europe/Helsinki
# DAILY_BRIEFING_PROMPT=Use recall_memory to find the user's home location and any relevant preferences. Then provide a concise morning briefing: get the weather for that location, check today's calendar events, and give a friendly summary of the day ahead.

# --- Timezone ---
AGENT_TZ=Europe/Helsinki  # IANA timezone for the agent (affects current-time in prompts and naive reminder datetimes)

# --- Agent persona ---
# AGENT_PERSONA=Act like a 1800s English butler. Be formal, composed, and impeccably polite.

# --- Memory ---
MEMORY_FILE=data/memory.json
# EMBEDDING_MODEL=nomic-embed-text  # pull with: ollama pull nomic-embed-text

# --- Context window (Ollama) ---
# OLLAMA_NUM_CTX=8192          # tokens allocated per request; Ollama default is 2048 which is too small for tool use
# MAX_TOOL_RESULT_CHARS=3000   # truncate individual tool results to this length before adding to messages
# MAX_MESSAGES_CHARS=           # override the auto-derived messages budget (OLLAMA_NUM_CTX*4 - 16000)

# --- Conversation summarization ---
# MAX_HISTORY_TURNS=20   # summarize when history exceeds this many turns
# SUMMARY_KEEP_RECENT=6  # keep this many recent turns verbatim

# --- HTTP trigger ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
# HTTP_API_KEY=your_secret_key_here  # uncomment to require Bearer auth

# --- Matrix trigger ---
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER=@pino:matrix.org
MATRIX_PASSWORD=your_matrix_password_here
MATRIX_ROOM_IDS=!roomid:matrix.org,!anotherroomid:matrix.org
MATRIX_STORE_PATH=./data/nio_store

# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- LLM (OpenAI-compatible) ---
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=gemma4:e4b
FAST_MODEL=qwen2.5:1.5b  # quick-acknowledgment model; set empty to disable

# --- Search ---
BRAVE_API_KEY=your_brave_api_key_here

# --- Weather ---
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# --- Workspace & data ---
# WORKSPACE_DIR=./data/workspace          # sandboxed directory for file tools and code execution
# AGENT_LOG_FILE=data/agent_history.jsonl
# HTTP_PUBLIC_URL=https://pino.example.com  # base URL used in share_file download links (HTTP trigger)

# --- Calendars (ICS) ---
# Name each calendar with CALENDAR_<name>=<ics_url>
# Get each URL from: Google Calendar → Settings → calendar → "Secret address in iCal format"
# CALENDAR_PERSONAL=https://calendar.google.com/calendar/ical/...
# CALENDAR_WORK=https://calendar.google.com/calendar/ical/...
# Comma-separated list of your email addresses — events you declined are filtered out
# USER_EMAILS=you@example.com,you@work.com

# --- Reminders ---
REMINDERS_FILE=data/reminders.json

# --- URL monitoring ---
# WATCHES_FILE=data/watches.json

# --- Recurring scheduled tasks ---
# SCHEDULED_TASKS_FILE=data/scheduled_tasks.json

# --- Memory consolidation ---
# Periodically reviews recent conversation history to extract new learnings into memory,
# and compacts core memories when they grow too numerous or redundant.
# Use MEMORY_CONSOLIDATION_CRON (5-field cron) OR MEMORY_CONSOLIDATION_INTERVAL_HOURS.
# Leave both unset to disable.
# MEMORY_CONSOLIDATION_CRON=0 3 * * *          # nightly at 03:00
# MEMORY_CONSOLIDATION_INTERVAL_HOURS=24        # alternative: every 24 hours
# MEMORY_CONSOLIDATION_CORE_THRESHOLD=8         # compact core memories when count >= this
# MEMORY_CONSOLIDATION_STATE_FILE=data/memory_consolidation_state.json
# MEMORY_CONSOLIDATION_MAX_HISTORY_CHARS=8000   # max chars of history to embed in the prompt

# --- Timezone ---
TIMEZONE=Europe/Helsinki  # IANA timezone for all time-related tasks (scheduler, prompts, reminders, briefing)

# --- Daily briefing ---
# DAILY_BRIEFING_TIME=08:00        # HH:MM in TIMEZONE
# DAILY_BRIEFING_PROMPT=Use recall_memory to find the user's home location and any relevant preferences. Then provide a concise morning briefing: get the weather for that location, check today's calendar events, and give a friendly summary of the day ahead.

# --- Agent persona ---
# AGENT_PERSONA=Act like a 1800s English butler. Be formal, composed, and impeccably polite.

# --- Memory ---
MEMORY_FILE=data/memory.json
# EMBEDDING_MODEL=nomic-embed-text  # pull with: ollama pull nomic-embed-text

# --- Workspace semantic index ---
# WORKSPACE_INDEX_FILE=data/workspace_index.json  # vector index for search_files_semantic

# --- Conversation history persistence ---
# HISTORY_DIR=data/history         # per-session history files (one JSON file per Matrix room / HTTP session)
# MAX_PERSISTED_HISTORY=200        # max messages to keep per session file

# --- Context window (Ollama) ---
# OLLAMA_NUM_CTX=8192          # tokens allocated per request; Ollama default is 2048 which is too small for tool use
# MAX_TOOL_RESULT_CHARS=3000   # truncate individual tool results to this length before adding to messages
# MAX_MESSAGES_CHARS=           # override the auto-derived messages budget (OLLAMA_NUM_CTX*4 - 16000)

# --- Conversation summarization ---
# MAX_HISTORY_CHARS=12000  # trigger summarization when total history character count exceeds this
# SUMMARY_KEEP_CHARS=4000  # target chars of recent history to keep verbatim after summarizing

# --- Python code execution ---
# CODE_EXEC_TIMEOUT=30          # default timeout in seconds for run_python (max 120)
# CODE_MAX_OUTPUT_CHARS=3000    # truncate run_python output to this length
# TOOL_RESULT_OFFLOAD_CHARS=1500  # tool results larger than this are saved to workspace/tool_outputs/ instead of inlined

# --- Verbose LLM tracing ---
# VERBOSE=1                     # print all LLM requests and responses to stderr (also: --verbose CLI flag)

# --- Background / sub-agent logs ---
# BG_LOG_DIR=data/logs          # directory for per-task background and sub-agent JSONL logs
# SUBAGENT_LOG_DIR=data/logs    # override log dir for sub-agent calls (defaults to BG_LOG_DIR)

# --- HTTP trigger ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
# HTTP_API_KEY=your_secret_key_here  # uncomment to require Bearer auth

# --- Matrix trigger ---
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER=@pino:matrix.org
MATRIX_PASSWORD=your_matrix_password_here
MATRIX_ROOM_IDS=!roomid:matrix.org,!anotherroomid:matrix.org
MATRIX_STORE_PATH=./data/nio_store
